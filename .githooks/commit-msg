#!/bin/sh
set -eu

message_file="$1"
first_line="$(sed -n '1p' "$message_file")"

if printf '%s\n' "$first_line" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?: .+'; then
  exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Use Conventional Commits:
  feat: add protein tokenizer
  fix(core): reject empty FASTA records
  docs: update roadmap
EOF

exit 1
