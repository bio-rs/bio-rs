{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/service-health-output.v0.json",
  "title": "bio-rs service health data payload",
  "type": "object",
  "required": [
    "schema_version",
    "service_name",
    "service_version",
    "status",
    "network_policy",
    "endpoints"
  ],
  "properties": {
    "schema_version": { "const": "biors.service_health.v0" },
    "service_name": { "const": "bio-rs" },
    "service_version": { "type": "string", "minLength": 1 },
    "status": { "const": "ok" },
    "network_policy": { "const": "local_first_no_external_calls" },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["method", "path", "operation_id"],
        "properties": {
          "method": { "enum": ["GET", "POST"] },
          "path": { "type": "string", "minLength": 1 },
          "operation_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
