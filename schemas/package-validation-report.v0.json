{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-validation-report.v0.json",
  "title": "bio-rs package validation report v0",
  "type": "object",
  "required": ["valid", "issues", "structured_issues"],
  "properties": {
    "valid": { "type": "boolean" },
    "issues": { "type": "array", "items": { "type": "string" } },
    "structured_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "field", "message"],
        "properties": {
          "code": {
            "enum": [
              "required_field",
              "missing_fixture",
              "invalid_shape",
              "invalid_checksum_format",
              "checksum_mismatch",
              "invalid_asset_path",
              "asset_read_failed",
              "layout_mismatch"
            ]
          },
          "field": { "type": "string" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
