{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/service-batch-sequence-validate-output.v0.json",
  "title": "bio-rs service batch sequence validation data payload",
  "type": "object",
  "required": ["schema_version", "inputs", "summary", "items"],
  "properties": {
    "schema_version": { "const": "biors.service_batch_sequence_validate.v0" },
    "inputs": { "type": "integer", "minimum": 1 },
    "summary": { "$ref": "#/$defs/batchSummary" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/itemReport" }
    }
  },
  "$defs": {
    "batchSummary": {
      "type": "object",
      "required": [
        "items",
        "fasta_records",
        "valid_records",
        "warning_count",
        "error_count",
        "kind_counts"
      ],
      "properties": {
        "items": { "type": "integer", "minimum": 1 },
        "fasta_records": { "type": "integer", "minimum": 0 },
        "valid_records": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "error_count": { "type": "integer", "minimum": 0 },
        "kind_counts": { "$ref": "#/$defs/kindCounts" }
      },
      "additionalProperties": false
    },
    "itemReport": {
      "type": "object",
      "required": [
        "id",
        "input_hash",
        "fasta_records",
        "valid_records",
        "warning_count",
        "error_count",
        "kind_counts"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "input_hash": { "type": "string", "pattern": "^fnv1a64:[0-9a-f]{16}$" },
        "fasta_records": { "type": "integer", "minimum": 0 },
        "valid_records": { "type": "integer", "minimum": 0 },
        "warning_count": { "type": "integer", "minimum": 0 },
        "error_count": { "type": "integer", "minimum": 0 },
        "kind_counts": { "$ref": "#/$defs/kindCounts" }
      },
      "additionalProperties": false
    },
    "kindCounts": {
      "type": "object",
      "required": ["protein", "dna", "rna"],
      "properties": {
        "protein": { "type": "integer", "minimum": 0 },
        "dna": { "type": "integer", "minimum": 0 },
        "rna": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
