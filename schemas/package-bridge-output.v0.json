{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-bridge-output.v0.json",
  "title": "bio-rs package bridge data payload",
  "type": "object",
  "required": [
    "ready",
    "backend",
    "target",
    "model_format",
    "model_metadata",
    "backend_config",
    "execution_provider",
    "compatibility_checks",
    "blocking_issues"
  ],
  "properties": {
    "ready": { "type": "boolean" },
    "backend": { "type": "string" },
    "target": { "type": "string" },
    "model_format": { "type": "string" },
    "model_metadata": { "$ref": "#/$defs/modelArtifactMetadata" },
    "backend_config": { "$ref": "#/$defs/backendConfig" },
    "execution_provider": { "type": "string" },
    "compatibility_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/compatibilityCheck" }
    },
    "blocking_issues": { "type": "array", "items": { "type": "string" } },
    "backend_capabilities": { "$ref": "#/$defs/backendCapabilities" },
    "benchmark_evidence": {
      "type": ["array", "null"],
      "items": { "$ref": "#/$defs/benchmarkEvidence" }
    },
    "regression_baseline": { "$ref": "#/$defs/regressionBaseline" }
  },
  "$defs": {
    "backendConfig": {
      "type": "object",
      "required": ["backend_id", "provider"],
      "properties": {
        "backend_id": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "version": { "type": ["string", "null"] },
        "model_artifact": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "modelArtifactMetadata": {
      "type": ["object", "null"],
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": ["string", "null"] },
        "architecture": { "type": ["string", "null"] },
        "task": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "compatibilityCheck": {
      "type": "object",
      "required": ["code", "passed", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "passed": { "type": "boolean" },
        "message": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "backendCapabilities": {
      "type": ["object", "null"],
      "required": [
        "deterministic",
        "supports_batch",
        "supports_streaming",
        "supported_inputs",
        "supported_outputs"
      ],
      "properties": {
        "deterministic": { "type": "boolean" },
        "supports_batch": { "type": "boolean" },
        "supports_streaming": { "type": "boolean" },
        "supported_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supported_outputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "benchmarkEvidence": {
      "type": "object",
      "required": [
        "benchmark_name",
        "backend_id",
        "workload_description",
        "recorded_at",
        "metrics"
      ],
      "properties": {
        "benchmark_name": { "type": "string", "minLength": 1 },
        "backend_id": { "type": "string", "minLength": 1 },
        "workload_description": { "type": "string", "minLength": 1 },
        "recorded_at": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/benchmarkMetric" }
        }
      },
      "additionalProperties": false
    },
    "benchmarkMetric": {
      "type": "object",
      "required": ["metric_name", "value", "unit"],
      "properties": {
        "metric_name": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "regressionBaseline": {
      "type": ["object", "null"],
      "required": [
        "baseline_name",
        "backend_id",
        "artifact_checksum",
        "benchmark_evidences"
      ],
      "properties": {
        "baseline_name": { "type": "string", "minLength": 1 },
        "backend_id": { "type": "string", "minLength": 1 },
        "artifact_checksum": { "type": "string", "minLength": 1 },
        "benchmark_evidences": {
          "type": "array",
          "items": { "$ref": "#/$defs/benchmarkEvidence" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
