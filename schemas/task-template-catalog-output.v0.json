{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/task-template-catalog-output.v0.json",
  "type": "array",
  "minItems": 6,
  "items": {
    "type": "object",
    "required": [
      "schema_version",
      "id",
      "kind",
      "title",
      "summary",
      "supported_inputs",
      "required_validations",
      "model_ready_fields",
      "output_expectations",
      "execution"
    ],
    "additionalProperties": false,
    "properties": {
      "schema_version": { "const": "biors.task_template.v0" },
      "id": {
        "enum": [
          "protein-classification-v0",
          "protein-embedding-generation-v0",
          "variant-effect-prediction-v0",
          "molecule-property-prediction-v0",
          "structure-validation-v0",
          "sequence-similarity-preprocess-v0"
        ]
      },
      "kind": {
        "enum": [
          "protein_classification",
          "protein_embedding_generation",
          "variant_effect_prediction",
          "molecule_property_prediction",
          "structure_validation",
          "sequence_similarity_preprocess"
        ]
      },
      "title": { "type": "string", "minLength": 1 },
      "summary": { "type": "string", "minLength": 1 },
      "supported_inputs": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/template_input" }
      },
      "required_validations": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/named_requirement" }
      },
      "model_ready_fields": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/required_field" }
      },
      "output_expectations": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/required_field" }
      },
      "execution": { "$ref": "#/$defs/execution" }
    }
  },
  "$defs": {
    "template_input": {
      "type": "object",
      "required": ["entity", "formats", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "entity": {
          "enum": [
            "protein_sequence",
            "protein_variant",
            "molecule",
            "protein_structure",
            "sequence_set"
          ]
        },
        "formats": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/input_format" }
        },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "input_format": {
      "type": "object",
      "required": ["format", "core_reader"],
      "additionalProperties": false,
      "properties": {
        "format": {
          "enum": [
            "fasta",
            "fastq",
            "csv",
            "tsv",
            "pdb",
            "smiles",
            "sdf",
            "mol2"
          ]
        },
        "core_reader": { "enum": ["executable", "contract_only"] }
      }
    },
    "named_requirement": {
      "type": "object",
      "required": ["id", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "required_field": {
      "type": "object",
      "required": ["name", "description", "required"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "execution_mode",
        "network_access",
        "external_model_calls",
        "uploads_input_data",
        "persistence"
      ],
      "additionalProperties": false,
      "properties": {
        "execution_mode": { "const": "local_template_contract" },
        "network_access": { "const": "none" },
        "external_model_calls": { "const": false },
        "uploads_input_data": { "const": false },
        "persistence": { "const": "caller_controlled" }
      }
    }
  }
}
