{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/report-output.v0.json",
  "title": "bio-rs shareable report output",
  "type": "object",
  "required": [
    "schema_version",
    "title",
    "summary",
    "status",
    "provenance",
    "sections",
    "human_report"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "biors.report.v0" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "warning", "fail", "unknown"] },
    "provenance": { "$ref": "#/$defs/provenance" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "human_report": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "inputHash": { "type": "string", "pattern": "^fnv1a64:[0-9a-f]{16}$" },
    "provenance": {
      "type": "object",
      "required": [
        "biors_core_version",
        "generator",
        "input_container",
        "input_kind",
        "input_raw_sha256",
        "input_canonical_sha256",
        "report_markdown_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "biors_core_version": { "type": "string", "minLength": 1 },
        "generator": { "const": "biors.report.v0" },
        "input_container": {
          "enum": ["raw_json", "cli_success_envelope", "cli_error_envelope"]
        },
        "input_kind": {
          "enum": [
            "cli_error",
            "bio_entity_export",
            "sequence_workflow_output",
            "validation_report",
            "generic_json"
          ]
        },
        "source_schema_version": { "type": "string", "minLength": 1 },
        "source_biors_version": { "type": "string", "minLength": 1 },
        "source_input_hash": { "$ref": "#/$defs/inputHash" },
        "input_raw_sha256": { "$ref": "#/$defs/sha256" },
        "input_canonical_sha256": { "$ref": "#/$defs/sha256" },
        "report_markdown_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "title", "summary", "metrics", "items"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "metrics": {
          "type": "array",
          "items": { "$ref": "#/$defs/metric" }
        },
        "items": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metric": {
      "type": "object",
      "required": ["label", "value"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string" }
      }
    }
  }
}
