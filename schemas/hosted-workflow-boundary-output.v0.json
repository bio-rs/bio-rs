{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/hosted-workflow-boundary-output.v0.json",
  "title": "bio-rs hosted workflow boundary contract data payload",
  "type": "object",
  "required": [
    "schema_version",
    "product_name",
    "core_version",
    "status",
    "execution_policy",
    "open_source_core",
    "hosted_layer",
    "workspace_model",
    "commercial_policy",
    "web_product_policy",
    "validation_requirements"
  ],
  "properties": {
    "schema_version": { "const": "biors.hosted_workflow_boundary.v0" },
    "product_name": { "const": "bio-rs" },
    "core_version": { "type": "string", "minLength": 1 },
    "status": { "const": "boundary_contract_only" },
    "execution_policy": {
      "type": "object",
      "required": [
        "local_first",
        "no_network_by_default",
        "biological_data_uploads_by_default",
        "external_model_calls_by_default",
        "telemetry_by_default",
        "remote_processing_requires_explicit_consent"
      ],
      "properties": {
        "local_first": { "const": true },
        "no_network_by_default": { "const": true },
        "biological_data_uploads_by_default": { "const": false },
        "external_model_calls_by_default": { "const": false },
        "telemetry_by_default": { "const": false },
        "remote_processing_requires_explicit_consent": { "const": true }
      },
      "additionalProperties": false
    },
    "open_source_core": { "$ref": "#/$defs/responsibility_set" },
    "hosted_layer": { "$ref": "#/$defs/responsibility_set" },
    "workspace_model": {
      "type": "array",
      "minItems": 3,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "name": { "const": "UserWorkspace" }
            },
            "required": ["name"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "name": { "const": "ProjectWorkspace" }
            },
            "required": ["name"]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "name": { "const": "WorkflowRun" }
            },
            "required": ["name"]
          }
        }
      ],
      "items": {
        "type": "object",
        "required": [
          "name",
          "status",
          "implemented_in_core",
          "owner",
          "data_classification",
          "required_controls"
        ],
        "properties": {
          "name": { "enum": ["UserWorkspace", "ProjectWorkspace", "WorkflowRun"] },
          "status": { "type": "string", "minLength": 1 },
          "implemented_in_core": { "const": false },
          "owner": { "const": "separate_hosted_layer" },
          "data_classification": { "type": "string", "minLength": 1 },
          "required_controls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "commercial_policy": {
      "type": "object",
      "required": [
        "paid_hosted_service_allowed",
        "billing_in_core",
        "must_remain_separate_from_open_source_core",
        "core_package_behavior_changes_for_hosted_service",
        "notes"
      ],
      "properties": {
        "paid_hosted_service_allowed": { "const": true },
        "billing_in_core": { "const": false },
        "must_remain_separate_from_open_source_core": { "const": true },
        "core_package_behavior_changes_for_hosted_service": { "const": false },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "web_product_policy": {
      "type": "object",
      "required": [
        "product_web_runtime_in_core",
        "product_landing_page_in_repository",
        "launch_track",
        "notes"
      ],
      "properties": {
        "product_web_runtime_in_core": { "const": false },
        "product_landing_page_in_repository": { "const": false },
        "launch_track": { "const": "1.0" },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "validation_requirements": {
      "type": "array",
      "minItems": 5,
      "contains": { "const": "no silent upload of biological data" },
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "responsibility_set": {
      "type": "object",
      "required": ["owner", "allowed", "excluded"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "allowed": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "excluded": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
