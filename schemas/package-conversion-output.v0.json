{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-conversion-output.v0.json",
  "title": "bio-rs package conversion data payload",
  "type": "object",
  "required": ["report", "manifest"],
  "properties": {
    "report": {
      "type": "object",
      "required": [
        "package",
        "from",
        "to",
        "compatibility",
        "converted",
        "automatic",
        "metadata_supplied"
      ],
      "properties": {
        "package": { "type": "string", "minLength": 1 },
        "from": { "enum": ["biors.package.v0", "biors.package.v1"] },
        "to": { "enum": ["biors.package.v0", "biors.package.v1"] },
        "compatibility": {
          "enum": ["backward_compatible", "migration_required", "unsupported"]
        },
        "converted": { "type": "boolean" },
        "automatic": { "type": "boolean" },
        "metadata_supplied": { "type": "boolean" },
        "output_path": { "type": "string", "minLength": 1 },
        "manifest_sha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "manifest": {
      "type": "object",
      "required": [
        "schema_version",
        "name",
        "model",
        "preprocessing",
        "postprocessing",
        "runtime",
        "fixtures"
      ],
      "properties": {
        "schema_version": { "enum": ["biors.package.v0", "biors.package.v1"] },
        "name": { "type": "string", "minLength": 1 },
        "package_layout": { "type": "object" },
        "metadata": { "type": "object" },
        "model": { "type": "object" },
        "tokenizer": { "type": "object" },
        "vocab": { "type": "object" },
        "preprocessing": { "type": "array" },
        "postprocessing": { "type": "array" },
        "runtime": { "type": "object" },
        "expected_input": { "type": "object" },
        "expected_output": { "type": "object" },
        "fixtures": { "type": "array", "minItems": 1 }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
