{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/sequence-debug-output.v0.json",
  "title": "bio-rs sequence debug data payload",
  "type": "object",
  "required": ["view", "records"],
  "properties": {
    "view": { "const": "sequence_debug.v0" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "normalized_sequence",
          "token_map",
          "error_visualization"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "normalized_sequence": { "type": "string" },
          "token_map": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["position", "residue", "token_id", "status"],
              "properties": {
                "position": { "type": "integer", "minimum": 1 },
                "residue": { "type": "string", "minLength": 1, "maxLength": 1 },
                "token_id": { "type": "integer", "minimum": 0, "maximum": 255 },
                "status": { "enum": ["standard", "warning", "error"] }
              },
              "additionalProperties": false
            }
          },
          "model_input": {
            "type": ["object", "null"]
          },
          "error_visualization": {
            "type": "object",
            "required": ["sequence", "markers", "legend"],
            "properties": {
              "sequence": { "type": "string" },
              "markers": { "type": "string" },
              "legend": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
