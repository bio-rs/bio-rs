{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-manifest.v0.json",
  "title": "bio-rs package manifest v0",
  "type": "object",
  "required": ["schema_version", "name", "model", "preprocessing", "postprocessing", "runtime", "fixtures"],
  "properties": {
    "schema_version": { "const": "biors.package.v0" },
    "name": { "type": "string", "minLength": 1 },
    "model": { "$ref": "#/$defs/artifact" },
    "tokenizer": { "$ref": "#/$defs/asset" },
    "vocab": { "$ref": "#/$defs/asset" },
    "preprocessing": { "type": "array", "items": { "$ref": "#/$defs/pipelineStep" } },
    "postprocessing": { "type": "array", "items": { "$ref": "#/$defs/pipelineStep" } },
    "runtime": {
      "type": "object",
      "required": ["backend", "target"],
      "properties": {
        "backend": { "enum": ["onnx-webgpu", "candle"] },
        "target": { "enum": ["browser-wasm-webgpu", "local-cpu"] }
      },
      "additionalProperties": false
    },
    "expected_input": { "$ref": "#/$defs/shape" },
    "expected_output": { "$ref": "#/$defs/shape" },
    "fixtures": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/fixture" } }
  },
  "additionalProperties": false,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["format", "path"],
      "properties": {
        "format": { "enum": ["onnx", "safetensors"] },
        "path": { "$ref": "#/$defs/packageRelativePath" },
        "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "metadata": { "$ref": "#/$defs/modelArtifactMetadata" }
      },
      "additionalProperties": false
    },
    "modelArtifactMetadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "task": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/packageRelativePath" },
        "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "contract_version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "pipelineStep": {
      "type": "object",
      "required": ["name", "implementation", "contract"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "implementation": { "type": "string", "minLength": 1 },
        "contract": { "type": "string", "minLength": 1 },
        "contract_version": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "shape": {
      "type": "object",
      "required": ["shape", "dtype"],
      "properties": {
        "shape": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" }
        },
        "dtype": { "enum": ["uint8", "float32"] }
      },
      "additionalProperties": false
    },
    "fixture": {
      "type": "object",
      "required": ["name", "input", "expected_output"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "input": { "$ref": "#/$defs/packageRelativePath" },
        "expected_output": { "$ref": "#/$defs/packageRelativePath" },
        "input_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "expected_output_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "packageRelativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/|^[A-Za-z]:|(^|/)\\.\\.(/|$)|(^|/)\\.(/|$)|//|\\\\"
      }
    }
  }
}
