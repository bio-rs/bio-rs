{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/pipeline-output.v0.json",
  "title": "bio-rs pipeline data payload",
  "type": "object",
  "required": ["pipeline", "ready", "steps", "workflow"],
  "properties": {
    "pipeline": { "enum": ["validate_tokenize_export.v0", "config_pipeline.v0"] },
    "ready": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "explain_plan": { "type": "boolean" },
    "config": {
      "type": "object",
      "required": ["schema_version", "name", "input", "export"],
      "properties": {
        "schema_version": { "const": "biors.pipeline.v0" },
        "name": { "type": "string", "minLength": 1 },
        "input": { "type": "string", "minLength": 1 },
        "export": { "const": "model-input-json" }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["name", "status", "records", "warning_count", "error_count"],
        "properties": {
          "name": { "enum": ["parse", "normalize", "validate", "tokenize", "export"] },
          "status": { "enum": ["planned", "passed", "failed", "blocked"] },
          "records": { "type": "integer", "minimum": 0 },
          "warning_count": { "type": "integer", "minimum": 0 },
          "error_count": { "type": "integer", "minimum": 0 },
          "output_sha256": { "$ref": "#/$defs/sha256" }
        },
        "additionalProperties": false
      }
    },
    "plan": {
      "type": "object",
      "required": ["schema_version", "name", "input", "stages"],
      "properties": {
        "schema_version": { "const": "biors.pipeline.v0" },
        "name": { "type": "string", "minLength": 1 },
        "input": { "type": "string", "minLength": 1 },
        "stages": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "required": ["name", "operation", "detail"],
            "properties": {
              "name": { "enum": ["parse", "normalize", "validate", "tokenize", "export"] },
              "operation": { "type": "string", "minLength": 1 },
              "detail": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "workflow": { "type": ["object", "null"] }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
