{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/doctor-output.v0.json",
  "title": "bio-rs doctor output",
  "type": "object",
  "required": ["cli_version", "platform", "toolchain", "checks"],
  "properties": {
    "cli_version": { "type": "string" },
    "platform": {
      "type": "object",
      "required": ["os", "arch"],
      "properties": {
        "os": { "type": "string" },
        "arch": { "type": "string" }
      },
      "additionalProperties": false
    },
    "toolchain": {
      "type": "object",
      "required": ["rustc", "cargo"],
      "properties": {
        "rustc": { "type": ["string", "null"] },
        "cargo": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "message"],
        "properties": {
          "name": { "type": "string" },
          "status": { "enum": ["pass", "warn", "fail"] },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
