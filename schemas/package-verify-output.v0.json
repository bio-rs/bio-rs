{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-verify-output.v0.json",
  "title": "bio-rs package verify data payload",
  "type": "object",
  "required": ["package", "fixtures", "passed", "failed", "results"],
  "properties": {
    "package": { "type": "string" },
    "fixtures": { "type": "integer", "minimum": 0 },
    "passed": { "type": "integer", "minimum": 0 },
    "failed": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "input_path",
          "expected_output_path",
          "status",
          "checksum_mismatch",
          "content_mismatch"
        ],
        "properties": {
          "name": { "type": "string" },
          "input_path": { "type": "string" },
          "expected_output_path": { "type": "string" },
          "observed_output_path": { "type": ["string", "null"] },
          "expected_output_hash": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
          "observed_output_hash": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" },
          "status": { "enum": ["failed", "missing", "passed"] },
          "checksum_mismatch": { "type": "boolean" },
          "content_mismatch": { "type": "boolean" },
          "issue_code": {
            "enum": [
              "expected_output_checksum_mismatch",
              "expected_output_read_failed",
              "fixture_input_checksum_mismatch",
              "fixture_input_read_failed",
              "observation_missing",
              "observation_path_invalid",
              "observed_output_read_failed",
              "output_checksum_mismatch",
              "output_content_mismatch"
            ]
          },
          "content_diff": {
            "type": "object",
            "required": [
              "expected_path",
              "observed_path",
              "expected_len",
              "observed_len"
            ],
            "properties": {
              "expected_path": { "type": "string" },
              "observed_path": { "type": "string" },
              "expected_len": { "type": "integer", "minimum": 0 },
              "observed_len": { "type": "integer", "minimum": 0 },
              "first_difference": {
                "type": "object",
                "required": ["byte_offset"],
                "properties": {
                  "byte_offset": { "type": "integer", "minimum": 0 },
                  "expected_byte": { "type": "integer", "minimum": 0, "maximum": 255 },
                  "observed_byte": { "type": "integer", "minimum": 0, "maximum": 255 }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "issue": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
