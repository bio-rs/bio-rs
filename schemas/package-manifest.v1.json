{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-manifest.v1.json",
  "title": "bio-rs package manifest v1",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "package_layout",
    "metadata",
    "model",
    "preprocessing",
    "postprocessing",
    "runtime",
    "fixtures"
  ],
  "properties": {
    "schema_version": { "const": "biors.package.v1" },
    "name": { "type": "string", "minLength": 1 },
    "package_layout": { "$ref": "#/$defs/packageLayout" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "model": { "$ref": "#/$defs/artifact" },
    "tokenizer": { "$ref": "#/$defs/asset" },
    "vocab": { "$ref": "#/$defs/asset" },
    "preprocessing": { "type": "array", "items": { "$ref": "#/$defs/pipelineStep" } },
    "postprocessing": { "type": "array", "items": { "$ref": "#/$defs/pipelineStep" } },
    "runtime": {
      "type": "object",
      "required": ["backend", "target"],
      "properties": {
        "backend": { "const": "onnx-webgpu" },
        "target": { "const": "browser-wasm-webgpu" }
      },
      "additionalProperties": false
    },
    "expected_input": { "$ref": "#/$defs/shape" },
    "expected_output": { "$ref": "#/$defs/shape" },
    "fixtures": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/fixture" } }
  },
  "additionalProperties": false,
  "$defs": {
    "packageLayout": {
      "type": "object",
      "required": ["manifest", "models", "fixtures", "docs"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "models": { "type": "string", "minLength": 1 },
        "tokenizers": { "type": "string", "minLength": 1 },
        "vocabs": { "type": "string", "minLength": 1 },
        "fixtures": { "type": "string", "minLength": 1 },
        "observed": { "type": "string", "minLength": 1 },
        "docs": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["license", "citation", "model_card"],
      "properties": {
        "license": {
          "type": "object",
          "required": ["expression"],
          "properties": {
            "expression": { "type": "string", "minLength": 1 },
            "file": { "$ref": "#/$defs/document" }
          },
          "additionalProperties": false
        },
        "citation": {
          "type": "object",
          "required": ["preferred_citation"],
          "properties": {
            "preferred_citation": { "type": "string", "minLength": 1 },
            "doi": { "type": "string", "minLength": 1 },
            "file": { "$ref": "#/$defs/document" }
          },
          "additionalProperties": false
        },
        "model_card": {
          "type": "object",
          "required": ["path", "summary", "intended_use", "limitations"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "summary": { "type": "string", "minLength": 1 },
            "intended_use": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "limitations": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "document": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": ["format", "path"],
      "properties": {
        "format": { "const": "onnx" },
        "path": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "contract_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pipelineStep": {
      "type": "object",
      "required": ["name", "implementation", "contract"],
      "properties": {
        "name": { "type": "string" },
        "implementation": { "type": "string" },
        "contract": { "type": "string" },
        "contract_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "shape": {
      "type": "object",
      "required": ["shape", "dtype"],
      "properties": {
        "shape": { "type": "array", "items": { "type": "string" } },
        "dtype": { "enum": ["uint8", "float32"] }
      },
      "additionalProperties": false
    },
    "fixture": {
      "type": "object",
      "required": ["name", "input", "expected_output"],
      "properties": {
        "name": { "type": "string" },
        "input": { "type": "string", "minLength": 1 },
        "expected_output": { "type": "string", "minLength": 1 },
        "input_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "expected_output_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    }
  }
}
