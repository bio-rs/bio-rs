{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-skeleton-output.v0.json",
  "title": "bio-rs package skeleton data payload",
  "type": "object",
  "required": [
    "package",
    "output_dir",
    "manifest_path",
    "manifest_sha256",
    "created_files",
    "next_commands",
    "notes"
  ],
  "properties": {
    "package": { "type": "string", "minLength": 1 },
    "output_dir": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string", "minLength": 1 },
    "manifest_sha256": { "$ref": "#/$defs/sha256" },
    "created_files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
