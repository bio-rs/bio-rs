{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/package-inspect-output.v0.json",
  "title": "bio-rs package inspect data payload",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "package_layout",
    "metadata",
    "model_format",
    "has_model_checksum",
    "runtime_backend",
    "runtime_target",
    "preprocessing_steps",
    "postprocessing_steps",
    "fixtures",
    "layout"
  ],
  "properties": {
    "schema_version": { "enum": ["biors.package.v0", "biors.package.v1"] },
    "name": { "type": "string" },
    "package_layout": {
      "type": ["object", "null"],
      "required": ["manifest", "models", "fixtures", "docs"],
      "properties": {
        "manifest": { "type": "string", "minLength": 1 },
        "models": { "type": "string", "minLength": 1 },
        "tokenizers": { "type": ["string", "null"] },
        "vocabs": { "type": ["string", "null"] },
        "pipelines": { "type": ["string", "null"] },
        "fixtures": { "type": "string", "minLength": 1 },
        "observed": { "type": ["string", "null"] },
        "docs": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": ["object", "null"],
      "required": ["license", "citation", "model_card"],
      "properties": {
        "license": { "type": "string", "minLength": 1 },
        "citation": { "type": "string", "minLength": 1 },
        "model_card": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "model_format": { "type": "string" },
    "has_model_checksum": { "type": "boolean" },
    "tokenizer": { "type": ["string", "null"] },
    "vocab": { "type": ["string", "null"] },
    "runtime_backend": { "type": "string" },
    "runtime_target": { "type": "string" },
    "preprocessing_steps": { "type": "integer", "minimum": 0 },
    "postprocessing_steps": { "type": "integer", "minimum": 0 },
    "fixtures": { "type": "integer", "minimum": 0 },
    "layout": {
      "type": "object",
      "required": ["model", "fixture_inputs", "fixture_outputs"],
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "tokenizer": { "type": ["string", "null"] },
        "vocab": { "type": ["string", "null"] },
        "pipeline_configs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fixture_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "fixture_outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
