{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-rs.dev/schemas/dataset-inspect-output.v0.json",
  "title": "bio-rs dataset inspect data payload",
  "type": "object",
  "required": [
    "provided_inputs",
    "descriptor",
    "metadata",
    "files",
    "total_bytes",
    "sample_count",
    "dataset_hash",
    "resolved_files",
    "samples"
  ],
  "properties": {
    "provided_inputs": { "type": "integer", "minimum": 1 },
    "descriptor": { "$ref": "#/$defs/datasetDescriptor" },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "files": { "type": "integer", "minimum": 1 },
    "total_bytes": { "type": "integer", "minimum": 0 },
    "sample_count": { "type": "integer", "minimum": 1 },
    "dataset_hash": { "$ref": "#/$defs/sha256" },
    "resolved_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "bytes", "sha256", "records"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "$ref": "#/$defs/sha256" },
          "records": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "dataset",
          "sample_id",
          "record_index",
          "file_path",
          "file_sha256",
          "sequence_length"
        ],
        "properties": {
          "dataset": { "$ref": "#/$defs/datasetDescriptor" },
          "sample_id": { "type": "string", "minLength": 1 },
          "record_index": { "type": "integer", "minimum": 0 },
          "file_path": { "type": "string", "minLength": 1 },
          "file_sha256": { "$ref": "#/$defs/sha256" },
          "sequence_length": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "datasetDescriptor": {
      "type": "object",
      "required": ["source", "version", "split"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "split": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
